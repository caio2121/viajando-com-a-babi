# ──────────────────────────────────────────
# Viajando com a Babi — .gitignore
# ──────────────────────────────────────────

# Pasta de backup interna (scripts Python e planilha)
bkp/

# Sistema operacional
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# Editores e IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# Node (caso venha a usar ferramentas locais)
node_modules/
npm-debug.log*
yarn-error.log*

# Python (scripts auxiliares locais)
__pycache__/
*.py[cod]
*.pyo
.env
venv/
.venv/

# Arquivos temporários
*.tmp
*.bak
*.log
